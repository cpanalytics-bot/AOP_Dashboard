# Copy this file to .env.local and fill in your Supabase project values.
# When these are absent, the prototype runs in MOCK mode using seeded
# in-memory data + localStorage drafts so you can demo without a backend.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key (used by admin scripts / seeding). NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=
